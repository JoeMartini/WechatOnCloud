# ============================================================
# WechatOnCloud OIDC 认证配置示例
# ============================================================
# 复制此文件为 .env 并填入你的配置，即可启用 OIDC 统一认证。
# 不配置 OIDC 时留空或注释掉，面板将回退到本地认证模式。

# ---------- 认证模式 ----------
# local  = 本地账号密码认证（默认）
# oidc   = OIDC 统一认证（保留本地登录作为回退）
WOC_AUTH_MODE=oidc

# ---------- OIDC Provider (通用标准配置) ----------
# Issuer URL：你的 OIDC IdP 的 OpenID Discovery 地址
# 示例：Keycloak: https://auth.example.com/realms/myrealm
#       Authentik: https://auth.example.com/application/o/myapp/
WOC_OIDC_ISSUER=https://auth.example.com/realms/myrealm

# Client ID：在 IdP 中注册的客户端标识
WOC_OIDC_CLIENT_ID=my-client-id

# Client Secret：在 IdP 中生成的客户端密钥
WOC_OIDC_CLIENT_SECRET=woc-panel-secret-change-me

# Redirect URI：OIDC 回调地址，必须与 IdP 注册时完全一致
WOC_OIDC_REDIRECT_URI=https://woc.example.com/api/auth/oidc/callback

# ---------- 角色映射 ----------
# Role Claim Path：ID Token 中角色数组的 JSON 路径（支持点号）
# Keycloak 默认: resource_access.${client_id}.roles
# 通用 IdP:      groups 或 roles
WOC_OIDC_ROLE_CLAIM=resource_access.my-client-id.roles

# 映射到 admin 角色的值
WOC_OIDC_ADMIN_ROLE=woc:admin

# 映射到 user 角色的值
WOC_OIDC_USER_ROLE=woc:user

# ---------- 用户预配 ----------
# 首次通过 OIDC 登录且未在本地注册时，是否自动创建本地用户映射
WOC_OIDC_AUTO_PROVISION=true

# ---------- Keycloak 扩展（可选）----------
# 仅在 Keycloak 环境下需要，用于实例角色的自动同步
# 非 Keycloak IdP 请保持注释或留空
WOC_KEYCLOAK_ADMIN_URL=http://keycloak:8080
WOC_KEYCLOAK_REALM=your-realm
WOC_KEYCLOAK_ADMIN_USER=admin
WOC_KEYCLOAK_ADMIN_PASS=admin-password

# ---------- 登出后跳转 ----------
# OIDC 登出后的返回地址（默认: /login）
WOC_OIDC_LOGOUT_REDIRECT_URI=https://woc.example.com/login
